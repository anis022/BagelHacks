# LI.FI API key — required for real bridge quotes
# Get yours at: https://li.fi/sdk (free tier available)
LIFI_API_KEY=your_lifi_api_key_here

# Alchemy API key — for reading on-chain state (optional)
# Get yours at: https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# PostgreSQL connection string — for persisting transfer history (optional)
# Without this, transfers are stored in memory (lost on restart)
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/swoin
# Example (Supabase): postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Example (local): postgresql://postgres:postgres@localhost:5432/swoin
DATABASE_URL=

# Next.js public URL (used for webhooks etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Solana RPC endpoint for wallet + transfer flow (defaults to devnet)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
